generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum MediaType {
  MOVIE
  TV
  VARIETY
  GAME
  ANIME
  MANGA
  BOOK
}

enum WatchStatus {
  WANT
  IN_PROGRESS
  COMPLETED
  DROPPED
  ON_HOLD
}

enum PlexStatus {
  IN_LIBRARY
  DELETED
}

enum GamePurchaseStatus {
  PURCHASED
  NOT_PURCHASED
}

model MediaItem {
  id             String       @id @default(cuid())
  mediaType      MediaType
  title          String
  originalTitle  String?
  coverLocalPath String?
  sourceUrl      String?
  description    String?
  releaseYear    Int?
  genres         String       @default("[]")
  status         WatchStatus
  myRating       Float?
  myReview       String?
  watchedAt      DateTime?
  imdbId         String?
  tmdbId         String?
  bangumiId      String?
  igdbId         String?
  malId          String?
  isbn           String?
  plexRatingKey  String?
  plexStatus     PlexStatus?
  plexSyncedAt   DateTime?
  extraData      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  activityLogs   ActivityLog[]
  downloadTasks  DownloadTask[]
  collections    CollectionItem[]
  gameProfile    GameProfile?

  @@index([mediaType])
  @@index([status])
  @@index([plexStatus])
  @@index([releaseYear])
  @@index([createdAt])
}

model GameProfile {
  id                     String              @id @default(cuid())
  itemId                 String              @unique
  purchaseStatus         GamePurchaseStatus?
  primaryPlatform        String?
  ownedPlatforms         String              @default("[]")
  normalPriceCny         Float?
  steamAppId             String?
  psnTitleId             String?
  psnConceptId           String?
  switchTitleId          String?
  playtimeForeverMinutes Int?
  playtime2WeeksMinutes  Int?
  lastPlayedAt           DateTime?
  externalIds            String?
  extraData              String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  item                   MediaItem           @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([steamAppId])
  @@index([psnTitleId])
  @@index([switchTitleId])
}

model Collection {
  id          String           @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       CollectionItem[]

  @@index([createdAt])
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  itemId       String
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  item         MediaItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([collectionId, itemId])
  @@index([collectionId, sortOrder])
  @@index([itemId])
}

model ActivityLog {
  id        String    @id @default(cuid())
  itemId    String
  action    String
  oldValue  String?
  newValue  String?
  createdAt DateTime  @default(now())
  item      MediaItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([createdAt])
}

model PtSubscription {
  id          String   @id @default(cuid())
  name        String
  rssUrl      String
  filterRules String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model DownloadTask {
  id          String    @id @default(cuid())
  itemId      String
  torrentName String
  filePath    String?
  status      String
  createdAt   DateTime  @default(now())
  item        MediaItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([status])
}
