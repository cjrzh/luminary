frontend/out/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
scraper_service/.venv/
your_scraper/.venv/

# 刮削临时输出（图片等体积大的文件不入库）
scraper_output/
*.nfo

# 系统文件
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
